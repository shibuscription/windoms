{
  "name": "windoms-minamigaoka",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5174",
    "seed:links": "node --env-file=.env ./scripts/seed-links.mjs",
    "preview:legacy-schedule-import": "node ./scripts/preview-legacy-schedule-import.mjs",
    "import:legacy-schedule-firestore": "node --env-file=.env ./scripts/import-legacy-schedule-to-firestore.mjs",
    "migrate:accounting-csv": "powershell -ExecutionPolicy Bypass -File ./scripts/normalize-accounting-csv.ps1",
    "cleanup:accounting-migration": "node --env-file=.env ./scripts/cleanup-accounting-period.mjs",
    "import:accounting-migration": "node --env-file=.env ./scripts/import-accounting-migration.mjs",
    "storage:cors": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-storage-cors.ps1"
  },
  "dependencies": {
    "firebase": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^5.4.12"
  }
}
